# =====================================================================
# vastra.ai — backend environment
# Copy to `.env` (kept out of git) and fill in real values.
# =====================================================================

# --- App ---
DEBUG=true
FRONTEND_ORIGIN=http://localhost:5173
# CORS: comma-separated allowed origins (falls back to FRONTEND_ORIGIN).
# Use "*" to allow any origin; optional regex for dynamic subdomains.
# CORS_ORIGINS=http://localhost:5173,https://app.example.com
# CORS_ORIGIN_REGEX=

# --- Cache / performance ---
# Redis speeds up slow/repeated reads; unset = in-process TTL cache.
# REDIS_URL=redis://localhost:6379/0

# --- LLM provider (text agents): "openai" or "bedrock" ---
# Switchable at runtime from Admin -> System (stored in app_settings).
LLM_PROVIDER=openai
# AWS Bedrock: authenticate with a Bedrock API key (bearer token) — no AWS
# access-key pair needed. Model must be enabled in the region's Model access.
# AWS_BEDROCK_API_KEY=
# BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_REGION=us-west-2
# AI_SERVICE_URL=http://localhost:8100

# --- Auth / JWT ---
# Use a long random string (>= 32 bytes). Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate-a-long-random-string-at-least-32-bytes
# ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days (default)

# --- Seed admin (created on first startup if no admin exists) ---
ADMIN_EMAIL=admin@vastra.ai
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Vastra Admin

# --- Database (defaults to SQLite in backend/vastra.db if unset) ---
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/vastra

# --- Object storage: local (dev) or s3 (Cloudflare R2 / AWS S3) ---
STORAGE_BACKEND=local
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_BUCKET=vastra-images
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- LLM reasoning / copy (Claude) ---
# Create at https://platform.claude.com
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-opus-4-8

# --- Image generation ---
# Provider: "gemini" (fast/cheap/photoreal, default) or "openai".
# IMAGE_PROVIDER=gemini
#
# Gemini 2.5 Flash Image ("nano banana") — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
#
# OpenAI gpt-image-1 (alternative) — https://platform.openai.com
OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-1
# OPENAI_IMAGE_QUALITY=high         # high matches the studio reference look
#
# DRY_RUN_IMAGES=true               # true = local placeholder, no API spend
# MAX_IMAGES_PER_SUBMISSION=4
# IMAGE_CONCURRENCY=4               # parallel generations per product (speed)

# --- Shopify app (live store) ---
# Scopes needed: read_products, write_products, write_files
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
#
# Option A — classic custom app (Store admin -> Settings -> Apps and sales
# channels -> Develop apps -> Create app). Reveal the Admin API access token:
SHOPIFY_ADMIN_TOKEN=shpat_...
#
# Option B — newer app (Dev Dashboard) that only shows a Client ID + Client
# Secret instead of a token. Leave SHOPIFY_ADMIN_TOKEN blank and set these two;
# the backend exchanges them for a 24h token via the client-credentials grant.
# This is server-to-server (no redirect URL), so it works in local dev. The app
# must belong to your org and be installed on a store you own, with scopes set.
# SHOPIFY_CLIENT_ID=...
# SHOPIFY_CLIENT_SECRET=shpss_...
# SHOPIFY_API_VERSION=2026-01
